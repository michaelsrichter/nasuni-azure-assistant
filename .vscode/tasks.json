{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "icon": {
        "id": "browser",
        "color": "terminal.ansiMagenta"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "demo",
        "showReuseMessage": false,
        "clear": true,
        "echo": true,
        "focus": false
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE.*starting.*$|^.*vite v.*$",
          "endsPattern": "^.*(?:ready in|Local:\\s+http).*$"
        }
      }
    },
    {
      "label": "demo: start (frontend)",
      "dependsOn": ["frontend: dev"],
      "dependsOrder": "parallel",
      "icon": {
        "id": "rocket",
        "color": "terminal.ansiGreen"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "demo",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "agent: dev",
      "type": "shell",
      "command": "dotnet",
      "args": ["run"],
      "options": {
        "cwd": "${workspaceFolder}/hosted-agent"
      },
      "isBackground": true,
      "icon": {
        "id": "server-process",
        "color": "terminal.ansiBlue"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "demo",
        "showReuseMessage": false,
        "clear": true,
        "echo": true,
        "focus": false
      },
      "problemMatcher": {
        "owner": "dotnet-agent",
        "pattern": {
          "regexp": "^\\s*(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*(Building|Restored|Determining projects|info:).*$",
          "endsPattern": "^.*(Now listening on|Application started|listening on).*$"
        }
      }
    },
    {
      "label": "proxy: dev",
      "type": "shell",
      "command": "node",
      "args": ["server.mjs"],
      "options": {
        "cwd": "${workspaceFolder}/frontend/proxy",
        "env": {
          "FOUNDRY_AGENT_ENDPOINT": "http://127.0.0.1:8088",
          "FOUNDRY_TOKEN_SCOPE": "",
          "INJECT_ISOLATION_KEYS": "true"
        }
      },
      "isBackground": true,
      "icon": {
        "id": "plug",
        "color": "terminal.ansiYellow"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "demo",
        "showReuseMessage": false,
        "clear": true,
        "echo": true,
        "focus": false
      },
      "problemMatcher": {
        "owner": "token-proxy",
        "pattern": {
          "regexp": "^\\s*(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "^.*token-proxy listening on.*$"
        }
      }
    },
    {
      "label": "demo: start (full stack)",
      "detail": "Runs the hosted agent (:8088), token-proxy sidecar (:8090) and the SPA (:5173) together.",
      "dependsOn": ["agent: dev", "proxy: dev", "frontend: dev"],
      "dependsOrder": "parallel",
      "icon": {
        "id": "rocket",
        "color": "terminal.ansiGreen"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "demo",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "infra: ensure-all",
      "type": "shell",
      "command": "dotnet",
      "args": ["run", "--project", "infra/Demo1.Infra/Demo1.Infra.csproj", "--", "ensure-all"],
      "options": { "cwd": "${workspaceFolder}" },
      "icon": {
        "id": "cloud",
        "color": "terminal.ansiCyan"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "tests: all",
      "type": "shell",
      "command": "dotnet",
      "args": ["test", "demo1.sln"],
      "options": { "cwd": "${workspaceFolder}" },
      "icon": {
        "id": "beaker",
        "color": "terminal.ansiYellow"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true,
        "focus": true
      },
      "group": "test",
      "problemMatcher": "$msCompile"
    }
  ]
}
