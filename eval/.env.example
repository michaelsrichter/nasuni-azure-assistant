# Copy to .env and fill in. All three values are required for a portal-logged run;
# --prep-only (call the agent + build rows, no scoring) needs only AGENT_API_URL.

# --- Agent under test ---------------------------------------------------------
# Public, unauthenticated Responses endpoint exposed by the deployed frontend.
# Defaults to the live demo if unset. Point this at a local proxy
# (http://127.0.0.1:8090/api/responses) to evaluate a locally running agent.
AGENT_API_URL=https://chatbot-web.ashyglacier-15904dad.westcentralus.azurecontainerapps.io/api/responses

# --- Foundry project (results land in the New Foundry portal Evaluations tab) --
# Project endpoint. Runs are created here and the harness prints a nextgen
# portal report URL (ai.azure.com/nextgen/.../build/evaluations/...).
AZURE_AI_PROJECT=https://researchfoundry.services.ai.azure.com/api/projects/researchProject

# --- Judge model (built-in evaluators run on this Foundry deployment) ----------
# Deployment name of the judge model (reuse the demo's gpt-4.1-mini).
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Auth is keyless (Entra ID via DefaultAzureCredential / az login). No API key needed.
