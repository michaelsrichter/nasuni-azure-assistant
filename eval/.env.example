# Copy to .env and fill in. Values without a default are required for a portal-logged run.
# A local-only run (--no-upload) needs only the AZURE_OPENAI_* judge settings and AGENT_API_URL.

# --- Agent under test ---------------------------------------------------------
# Public, unauthenticated Responses endpoint exposed by the deployed frontend.
# Defaults to the live demo if unset. Point this at a local proxy
# (http://127.0.0.1:8090/api/responses) to evaluate a locally running agent.
AGENT_API_URL=https://chatbot-web.ashyglacier-15904dad.westcentralus.azurecontainerapps.io/api/responses

# --- Judge model (built-in evaluators call this AOAI deployment) ---------------
# The Foundry account's Azure OpenAI inference endpoint.
AZURE_OPENAI_ENDPOINT=https://researchfoundry.openai.azure.com/
# Deployment name of the judge model (reuse the demo's gpt-4.1-mini).
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional: set an API key to use key auth. Leave blank to use Entra ID
# (DefaultAzureCredential / az login), which is the recommended, keyless path.
AZURE_OPENAI_API_KEY=

# --- Foundry project (results upload / portal Evaluations tab) ----------------
# Project endpoint. When set, eval results are logged to the Foundry portal and
# the run prints a studio_url. Omit (or use --no-upload) for a purely local run.
AZURE_AI_PROJECT=https://researchfoundry.services.ai.azure.com/api/projects/researchProject
